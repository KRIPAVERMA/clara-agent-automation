      "id": "1a2b3c4d-0001-0001-0001-000000000004",
      "name": "Step 1 â€” Transcribe Onboarding",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "jsCode": "const r = $input.first().json;\n// Step 1 is optional â€” transcripts may already exist if Whisper is not installed\nif (r.status === 'error') {\n  const combined = (r.stdout || '') + (r.stderr || '');\n  if (/Missing Python|whisper|ffmpeg|No .mp4|No .m4a/i.test(combined)) {\n    return [{ json: { step: 1, status: 'ok', note: 'Whisper not installed â€” using existing .txt transcripts.' } }];\n  }\n  throw new Error('Step 1 failed: ' + (r.stderr || r.stdout || JSON.stringify(r)));\n}\nreturn [{ json: { step: 1, status: 'ok', output: r.stdout || '' } }];"
      },
      "id": "1a2b3c4d-0001-0001-0001-000000000005",
      "name": "Check Step 1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
