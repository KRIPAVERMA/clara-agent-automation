      "id": "1a2b3c4d-0001-0001-0001-000000000006",
      "name": "Step 2 â€” Extract Account Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 300]
    },
    {
      "parameters": {
        "jsCode": "const r = $input.first().json;\nif (r.status === 'error') {\n  throw new Error('Step 2 failed: ' + (r.stderr || r.stdout || JSON.stringify(r)));\n}\nconst accountMatches = (r.stdout || '').match(/Account ID\\s*:\\s*(\\S+)/g) || [];\nconst accounts = accountMatches.map(m => m.replace(/Account ID\\s*:\\s*/, '').trim());\nreturn [{ json: { step: 2, status: 'ok', accounts, output: r.stdout || '' } }];"
      },
